{
  "name": "lablink-backend",
  "version": "1.0.0",
  "description": "Backend LabLink",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
"scripts": {
  "dev": "tsx watch src/index.ts",
  "build": "tsc",
  "start": "node dist/index.js",
  "migrate:make": "knex migrate:make --knexfile knexfile.ts -x ts",
  "migrate:latest": "knex migrate:latest --knexfile knexfile.ts",
  "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts"
},
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "sqlite3": "^5.1.7",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
